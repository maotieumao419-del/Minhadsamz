{
    "rules": [
        {
            "rule_name": "Optimize_Placement_No_Order",
            "conditions": {
                "impressions_min": 1000,
                "clicks_min": 10,
                "orders_max": 0
            },
            "match_type_logic": {
                "Broad": {
                    "target_entity": "Bidding Adjustment",
                    "placement_type": "Placement Product Page",
                    "set_percentage": 0,
                    "action": "Update"
                },
                "Phrase": {
                    "target_entity": "Bidding Adjustment",
                    "placement_type": "Placement Product Page",
                    "set_percentage": 10,
                    "action": "Update"
                }
            },
            "log_template": "Placement Adjusted: {match_type} logic applied due to {clicks} clicks and 0 orders"
        },
        {
            "rule_name": "Boost_Low_Impression_Exact",
            "conditions": {
                "impressions_max": 99,
                "clicks_max": 0
            },
            "match_type_logic": {
                "Exact": {
                    "target_entity": "Keyword",
                    "adjust_bid_by": 0.1,
                    "action": "Update"
                }
            },
            "log_template": "Bid Increased (+0.1): Exact match bid adjusted due to low impressions ({impressions})"
        },
        {
            "rule_name": "Fatal_Bleeder_Zero_Sales",
            "conditions": {
                "clicks_min": 15,
                "orders_max": 0
            },
            "action": "Paused",
            "target_entity": "Keyword",
            "log_template": "Paused (Fatal Bleeder): {clicks} Clicks, {orders} Orders. CVR = 0%, cắt giảm ngay lập tức."
        },
        {
            "rule_name": "Poor_CVR_Underperformer",
            "conditions": {
                "clicks_min": 25,
                "orders_max": 1
            },
            "action": "Paused",
            "target_entity": "Keyword",
            "log_template": "Paused (Poor CVR): {clicks} Clicks chỉ đổi được {orders} Order. CVR ước tính <= 4%, Listing yếu so với đối thủ trên Keyword này."
        },
        {
            "rule_name": "High_Traffic_Illusion",
            "conditions": {
                "impressions_min": 5000,
                "clicks_min": 30,
                "orders_max": 0
            },
            "action": "Paused",
            "target_entity": "Keyword",
            "log_template": "Paused (Traffic Illusion): Nhận {impressions} Imps và {clicks} Clicks nhưng 0 Orders. Khách hàng tò mò click nhưng rớt đài ở bước Checkout."
        },
        {
            "rule_name": "Low_CTR_Relevance_Penalty",
            "conditions": {
                "impressions_min": 3000,
                "clicks_max": 5
            },
            "action": "Paused",
            "target_entity": "Keyword",
            "log_template": "Paused (Low CTR): {impressions} Imps nhưng chỉ có {clicks} Clicks. CTR ước tính < 0.16%, ảnh hưởng điểm chất lượng."
        },
        {
            "rule_name": "Exact_Match_Relevance_Drop",
            "conditions": {
                "impressions_min": 2000,
                "clicks_max": 3,
                "orders_max": 0
            },
            "match_type_logic": {
                "exact": {
                    "action": "Paused",
                    "target_entity": "Keyword"
                }
            },
            "log_template": "Paused (Exact Drop): Chạy Exact [{match_type}] nhưng {impressions} Imps chỉ có {clicks} Clicks (CTR cực thấp). Listing không khớp intent của Exact Keyword này."
        },
        {
            "rule_name": "Broad_Match_Discovery_Filter",
            "conditions": {
                "impressions_min": 1000,
                "clicks_max": 2,
                "orders_max": 0
            },
            "match_type_logic": {
                "broad": {
                    "action": "Paused",
                    "target_entity": "Keyword"
                },
                "auto": {
                    "action": "Paused",
                    "target_entity": "Keyword"
                }
            },
            "log_template": "Paused (Discovery Waste): {impressions} Imps, {clicks} Clicks trên Match Type [{match_type}]. Intent khách hàng không khớp."
        },
        {
            "rule_name": "Scaling_Winning_Target",
            "conditions": {
                "clicks_min": 5,
                "orders_min": 3
            },
            "action": "Update",
            "target_entity": "Bidding Adjustment",
            "placement_type": "Placement Top",
            "set_percentage": "25",
            "log_template": "Scaling: {orders} Orders sau {clicks} Clicks (CVR cao). Tăng 25% TOS Bid Modifier để push Rank."
        },
        {
            "rule_name": "Traffic_Starved_Winner",
            "conditions": {
                "impressions_max": 800,
                "clicks_min": 4,
                "orders_min": 2
            },
            "action": "Update",
            "target_entity": "Bidding Adjustment",
            "placement_type": "Placement Top",
            "set_percentage": "20",
            "log_template": "Update (Starved Winner): Chỉ có {impressions} Imps nhưng ra tới {orders} Orders. CVR cực tốt. Cần tăng Bid/Placement để kéo thêm Impressions."
        }
    ]
}